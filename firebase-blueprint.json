{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" }
      },
      "required": ["id", "username", "name"]
    },
    "Post": {
      "title": "Post",
      "description": "A user's post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "caption": { "type": "string" },
        "likes": { "type": "number" },
        "likedBy": { "type": "array" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "imageUrl", "caption", "likes", "likedBy", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "users": { "type": "array" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "users", "lastMessage", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "chatId", "senderId", "text", "createdAt"]
    },
    "Follow": {
      "title": "Follow",
      "description": "A follow relationship",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "followerId", "followingId", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "postId", "userId", "text", "createdAt"]
    },
    "Story": {
      "title": "Story",
      "description": "User story (24 hr expires)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string" },
        "expiresAt": { "type": "string" }
      },
      "required": ["id", "userId", "imageUrl", "createdAt", "expiresAt"]
    }
  },
  "firestore": {
    "/stories/{storyId}": {
      "schema": { "$ref": "#/entities/Story" },
      "description": "24 hour stories"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile data"
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Posts created by users"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments on posts"
    },
    "/follows/{followId}": {
      "schema": { "$ref": "#/entities/Follow" },
      "description": "Follows collection"
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Chats collection"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages subcollection"
    }
  }
}
